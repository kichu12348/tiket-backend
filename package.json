{
  "name": "tiket-backend",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "author": {
    "name": "Mahadevan Reji"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate --config ./drizzle.config.ts",
    "db:push": "bun --bun drizzle-kit push --config ./drizzle.config.ts",
    "db:migrate": "bun --bun drizzle-kit migrate --config ./drizzle.config.ts",
    "db:studio": "bun --bun drizzle-kit studio --config ./drizzle.config.ts",
    "db:init": "bun db:generate && bun db:push",
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "bun run build.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.0"
  },
  "peerDependencies": {
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/jwt": "^10.2.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0"
  }
}